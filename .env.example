# ─── Joshua Terminal — environment config ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OANDA ─────────────────────────────────────────────────────────────────────
# Free practice account: https://www.oanda.com/
# Token: My Account → Manage API Access → Generate token
# Account ID: shown on the account dashboard
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice      # practice | live

# ── Telegram ──────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token below
# 2. Send any message to your new bot
# 3. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Look for "chat":{"id": <YOUR_CHAT_ID>} and paste it below
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

#---- Local host self certificate------
SSL_CERT=           # your localhost.pem file
SSL_KEY=            # your localhost-key.pem file
